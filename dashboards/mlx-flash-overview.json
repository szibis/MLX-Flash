{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Server Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Model",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [{ "expr": "mlx_flash_info", "legendFormat": "{{model}}" }],
      "options": { "textMode": "name", "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "type": "stat",
      "title": "Uptime",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "targets": [{ "expr": "mlx_flash_uptime_seconds", "legendFormat": "uptime" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "Total Requests",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "targets": [{ "expr": "mlx_flash_requests_total", "legendFormat": "requests" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "type": "stat",
      "title": "Total Tokens",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "targets": [{ "expr": "mlx_flash_tokens_generated_total", "legendFormat": "tokens" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },
    {
      "type": "stat",
      "title": "Memory Pressure",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "targets": [{ "expr": "mlx_flash_memory_pressure", "legendFormat": "pressure" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Normal", "color": "green" }, "1": { "text": "Warning", "color": "yellow" }, "2": { "text": "Critical", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "yellow" }, { "value": 2, "color": "red" }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Workers Healthy",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "targets": [{ "expr": "mlx_flash_workers_healthy", "legendFormat": "healthy" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "type": "stat",
      "title": "Active Sessions",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "targets": [{ "expr": "mlx_flash_sessions_active", "legendFormat": "sessions" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } } }
    },
    {
      "type": "row",
      "title": "Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Rate",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "rate(mlx_flash_requests_total[1m])", "legendFormat": "req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "gradientMode": "scheme" } } }
    },
    {
      "type": "timeseries",
      "title": "Token Generation Rate",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [{ "expr": "rate(mlx_flash_tokens_generated_total[1m])", "legendFormat": "tok/s" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "gradientMode": "scheme" }, "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },
    {
      "type": "row",
      "title": "Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        { "expr": "mlx_flash_memory_total_bytes", "legendFormat": "Total" },
        { "expr": "mlx_flash_memory_active_bytes", "legendFormat": "Active" },
        { "expr": "mlx_flash_memory_wired_bytes", "legendFormat": "Wired" },
        { "expr": "mlx_flash_memory_compressed_bytes", "legendFormat": "Compressed" },
        { "expr": "mlx_flash_memory_free_bytes", "legendFormat": "Free" },
        { "expr": "mlx_flash_memory_inactive_bytes", "legendFormat": "Inactive" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "none" } } } }
    },
    {
      "type": "timeseries",
      "title": "Memory Used Ratio + Swap",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        { "expr": "mlx_flash_memory_used_ratio", "legendFormat": "Used Ratio" },
        { "expr": "mlx_flash_memory_swap_used_bytes", "legendFormat": "Swap Used", "yaxis": 2 }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 20, "gradientMode": "scheme" } },
        "overrides": [{ "matcher": { "id": "byName", "options": "Swap Used" }, "properties": [{ "id": "unit", "value": "bytes" }, { "id": "custom.axisPlacement", "value": "right" }, { "id": "max" }] }]
      }
    },
    {
      "type": "row",
      "title": "Workers",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Worker In-Flight Requests",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [{ "expr": "mlx_flash_worker_inflight", "legendFormat": "worker:{{worker}}" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } } }
    },
    {
      "type": "timeseries",
      "title": "Worker Request Rate",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [{ "expr": "rate(mlx_flash_worker_requests_total[1m])", "legendFormat": "worker:{{worker}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20 } } }
    },
    {
      "type": "row",
      "title": "Cache (Expert Streaming)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "targets": [{ "expr": "mlx_flash_cache_hit_ratio", "legendFormat": "hit ratio" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 30, "gradientMode": "scheme" }, "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "type": "timeseries",
      "title": "Cache Entries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "targets": [{ "expr": "mlx_flash_cache_entries", "legendFormat": "experts cached" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 }, "color": { "mode": "fixed", "fixedColor": "orange" } } }
    },
    {
      "type": "row",
      "title": "Python Workers (per-worker detail)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Python Worker Token Rate",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "targets": [{ "expr": "rate(mlx_flash_python_worker_tokens_total[1m])", "legendFormat": "worker:{{worker}} ({{model}})" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "gradientMode": "scheme" } } }
    },
    {
      "type": "timeseries",
      "title": "Python Worker Request Rate",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "targets": [{ "expr": "rate(mlx_flash_python_worker_requests_total[1m])", "legendFormat": "worker:{{worker}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20 } } }
    },
    {
      "type": "stat",
      "title": "Python Worker Memory Pressure",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 50 },
      "targets": [{ "expr": "mlx_flash_python_worker_memory_pressure", "legendFormat": "worker:{{worker}}" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Normal", "color": "green" }, "1": { "text": "Warning", "color": "yellow" }, "2": { "text": "Critical", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "yellow" }, { "value": 2, "color": "red" }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Python Worker Model Loaded",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 50 },
      "targets": [{ "expr": "mlx_flash_python_worker_model_loaded", "legendFormat": "worker:{{worker}} {{model}}" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Not loaded", "color": "red" }, "1": { "text": "Loaded", "color": "green" } } }
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Python Worker Uptime",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 54 },
      "targets": [{ "expr": "mlx_flash_python_worker_uptime_seconds", "legendFormat": "worker:{{worker}}" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["mlx-flash", "llm", "inference", "apple-silicon"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MLX-Flash Overview",
  "uid": "mlx-flash-overview",
  "version": 1
}
